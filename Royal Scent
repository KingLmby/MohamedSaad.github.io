<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Royal Scents</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    background: #0f0f0f;
    color: white;
}

/* NAVBAR */
nav {
    display: flex;
    justify-content: space-between;
    padding: 20px 50px;
    background: black;
}

nav h1 {
    color: gold;
}

nav a {
    color: white;
    text-decoration: none;
    margin: 0 10px;
}

/* HERO */
.hero {
    height: 90vh;
    background: url('https://images.unsplash.com/photo-1592945403244-b3fbafd7f539') center/cover;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
}

.hero h2 {
    font-size: 50px;
}

.hero p {
    font-size: 20px;
}

/* PRODUCTS */
.products {
    padding: 50px;
    text-align: center;
}

.products h2 {
    color: gold;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-top: 30px;
}

.card {
    background: #1a1a1a;
    padding: 20px;
    border-radius: 10px;
    transition: 0.3s;
}

.card:hover {
    transform: scale(1.05);
}

.card img {
    width: 100%;
    border-radius: 10px;
}

.price {
    color: gold;
    font-size: 18px;
}

button {
    background: gold;
    border: none;
    padding: 10px 20px;
    cursor: pointer;
    margin-top: 10px;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 20px;
    background: black;
    margin-top: 50px;
}
</style>
</head>

<body>

<!-- NAVBAR -->
<nav>
    <h1>Royal Scents</h1>
    <div>
        <a href="#">Home</a>
        <a href="#">Perfumes</a>
        <a href="#">Contact</a>
    </div>
</nav>

<!-- HERO -->
<section class="hero">
    <div>
        <h2>Luxury Perfumes</h2>
        <p>Discover your signature scent</p>
    </div>
</section>

<!-- PRODUCTS -->
<section class="products">
    <h2>Best Sellers</h2>

    <div class="grid">

        <div class="card">
            <img src="https://images.unsplash.com/photo-1585386959984-a4155224a1ad">
            <h3>Dior Sauvage</h3>
            <p>Fresh & Strong</p>
            <p class="price">$120</p>
            <button>Add to Cart</button>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1615634260167-c8cdede054de">
            <h3>Chanel No.5</h3>
            <p>Classic & Elegant</p>
            <p class="price">$150</p>
            <button>Add to Cart</button>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1594035910387-fea47794261f">
            <h3>YSL Libre</h3>
            <p>Modern & Bold</p>
            <p class="price">$130</p>
            <button>Add to Cart</button>
        </div>

    </div>
</section>

<!-- FOOTER -->
<footer>
    <p>© 2026 Royal Scents - All Rights Reserved</p>
</footer>

</body>
</html>
